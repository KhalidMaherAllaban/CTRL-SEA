# Docker cannot use Windows integrated authentication from a Linux container.
# Use a TCP-enabled SQL login and URL-encode special characters in credentials.
DOCKER_DATABASE_URL=mssql+pyodbc://replace-with-sql-user:replace-with-sql-password@host.docker.internal:1433/ITI_Graduation_PortWatch?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
BACKEND_PORT=8000
FRONTEND_PORT=3000
